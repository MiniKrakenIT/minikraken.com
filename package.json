{
	"name": "minikraken.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev --host",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "bun --bun svelte-kit sync",
		"check": "bun --bun svelte-kit sync && bunx sv check --tsconfig ./tsconfig.json && bun run format && bun run lint",
		"check:watch": "bun --bun svelte-kit sync && bunx sv check --tsconfig ./tsconfig.json --watch",
		"release": "bunx release-it",
		"release:ci": "bunx release-it --ci",
		"email:dev": "email dev --dir src/lib/mailing/templates",
		"email:build": "email dev --packageManager bun --dir src/lib/mailing/templates",
		"email:export": "email export --dir src/lib/mailing/templates ",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"eslint-plugin-unicorn": "^63.0.0",
		"vitest": "^4.1.1",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"playwright": "^1.58.2",
		"@inlang/paraglide-js": "^2.15.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"@release-it/conventional-changelog": "^10.0.6",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/bun": "^1.3.11",
		"globals": "^17.4.0",
		"lefthook": "^2.1.4",
		"release-it": "^19.2.4",
		"sharp": "^0.34.5",
		"super-sitemap": "^1.0.7",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"svelte-language-server": "^0.17.29",
		"sveltekit-superforms": "^2.30.0",
		"svgo": "^4.0.1",
		"tailwindcss": "^4.2.2",
		"tatami-ng": "^0.8.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"typescript-svelte-plugin": "^0.3.50",
		"vite": "^8.0.2",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-image-optimizer": "^2.0.3",
		"@vitest/browser-playwright": "^4.1.1",
		"daisyui": "^5.5.19"
	},
	"dependencies": {
		"mdsvex": "^0.12.7",
		"motion": "^12.38.0",
		"nanoid": "^5.1.7",
		"posthog-js": "^1.363.5",
		"resend": "^6.9.4",
		"runed": "^0.37.1",
		"valibot": "^1.3.1"
	},
	"browserslist": [
		"defaults and fully supports es6-module"
	],
	"trustedDependencies": [
		"@sveltejs/kit",
		"@tailwindcss/oxide",
		"core-js",
		"esbuild",
		"lefthook",
		"sharp",
		"svelte-preprocess"
	]
}
