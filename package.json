{
	"name": "minikraken.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev --host",
		"build": "bun --bun vite build",
		"postbuild": "bun run -bun tooling/build/post-build.ts",
		"preview": "bun --bun vite preview",
		"prepare": "bun --bun svelte-kit sync",
		"check": "bun --bun svelte-kit sync && bunx sv check --tsconfig ./tsconfig.json && bunx --bun biome check --write .",
		"check:watch": "bun --bun svelte-kit sync && bunx sv check --tsconfig ./tsconfig.json --watch",
		"format": "bunx --bun biome format --write .",
		"lint": "bunx --bun biome check --write .",
		"release": "bunx release-it",
		"release:ci": "bunx release-it --ci",
		"email:dev": "email dev --dir src/lib/mailing/templates",
		"email:build": "email dev --packageManager bun --dir src/lib/mailing/templates",
		"email:export": "email export --dir src/lib/mailing/templates "
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.3",
		"@jonasbuerger/svelte-adapter-bun": "^2.3.0",
		"@release-it/conventional-changelog": "^10.0.1",
		"@sveltejs/adapter-node": "^5.2.13",
		"@sveltejs/enhanced-img": "^0.7.0",
		"@sveltejs/kit": "^2.27.1",
		"@sveltejs/vite-plugin-svelte": "^6.1.0",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@types/bun": "^1.2.19",
		"globals": "^16.3.0",
		"lefthook": "^1.12.3",
		"release-it": "^19.0.4",
		"sharp": "^0.34.3",
		"super-sitemap": "^1.0.5",
		"svelte": "^5.38.0",
		"svelte-check": "^4.3.1",
		"svelte-language-server": "^0.17.18",
		"sveltekit-superforms": "^2.27.1",
		"svgo": "^4.0.0",
		"tailwindcss": "^4.1.11",
		"tatami-ng": "^0.8.16",
		"typescript": "^5.9.2",
		"typescript-svelte-plugin": "^0.3.49",
		"vite": "^7.0.6",
		"vite-plugin-devtools-json": "^0.4.1",
		"vite-plugin-image-optimizer": "^2.0.2"
	},
	"dependencies": {
		"mdsvex": "^0.12.6",
		"motion": "^12.23.12",
		"nanoid": "^5.1.5",
		"posthog-js": "^1.258.6",
		"resend": "^5.0.0",
		"runed": "^0.31.1",
		"valibot": "^1.1.0"
	},
	"browserslist": ["defaults and fully supports es6-module"],
	"trustedDependencies": [
		"@sveltejs/kit",
		"@tailwindcss/oxide",
		"core-js",
		"esbuild",
		"lefthook",
		"sharp",
		"svelte-preprocess"
	]
}
