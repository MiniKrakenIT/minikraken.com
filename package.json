{
	"name": "minikraken.com",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev --host",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "bun --bun svelte-kit sync",
		"check": "bun --bun svelte-kit sync && bun run format && bun run lint && bunx sv check --tsconfig ./tsconfig.json",
		"check:watch": "bun --bun svelte-kit sync && bunx sv check --tsconfig ./tsconfig.json --watch",
		"release": "bunx release-it",
		"release:ci": "bunx release-it --ci",
		"email:dev": "email dev --dir src/lib/mailing/templates",
		"email:build": "email dev --packageManager bun --dir src/lib/mailing/templates",
		"email:export": "email export --dir src/lib/mailing/templates ",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"agents:update": "bunx skills update -p"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.0",
		"@release-it/conventional-changelog": "^10.0.6",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/enhanced-img": "^0.10.4",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/language-server": "^0.14.29",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@typescript/native-preview": "^7.0.0-dev.20260514.1",
		"@vitest/browser-playwright": "^4.1.6",
		"daisyui": "^5.5.19",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"eslint-plugin-unicorn": "^64.0.0",
		"globals": "^17.6.0",
		"gray-matter": "^4.0.3",
		"lefthook": "^2.1.6",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"prettier-plugin-tailwindcss": "^0.7.4",
		"release-it": "^20.0.1",
		"remark-frontmatter": "^5.0.0",
		"remark-lint-frontmatter-schema": "^3.15.4",
		"sharp": "^0.34.5",
		"super-sitemap": "^1.0.12",
		"svelte": "^5.55.7",
		"svelte-check": "^4.4.8",
		"svelte-language-server": "^0.17.31",
		"sveltekit-superforms": "^2.30.1",
		"svgo": "^4.0.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"typescript-svelte-plugin": "^0.3.52",
		"vite": "^8.0.13",
		"vite-plugin-browser-sync": "^7.0.0",
		"vite-plugin-devtools-json": "^1.0.0",
		"vite-plugin-image-optimizer": "^2.0.3",
		"vitest": "^4.1.6",
		"openapi-types": "^12.1.3"
	},
	"dependencies": {
		"@opentelemetry/api": "^1.9.1",
		"@opentelemetry/auto-instrumentations-node": "^0.73.0",
		"@opentelemetry/exporter-trace-otlp-proto": "^0.215.0",
		"@opentelemetry/instrumentation-undici": "^0.25.0",
		"@opentelemetry/sdk-node": "^0.215.0",
		"elysia": "^1.4.28",
		"import-in-the-middle": "^3.0.1",
		"mdsvex": "^0.12.7",
		"motion": "^12.38.0",
		"motion-plus-dom": "^2.11.2",
		"nanoid": "^5.1.11",
		"posthog-js": "^1.373.4",
		"resend": "^6.12.3",
		"runed": "^0.37.1",
		"typebox": "^1.1.38",
		"valibot": "^1.4.0"
	},
	"browserslist": [
		"defaults and fully supports es6-module"
	],
	"trustedDependencies": [
		"@sveltejs/kit",
		"@tailwindcss/oxide",
		"core-js",
		"esbuild",
		"lefthook",
		"sharp",
		"svelte-preprocess"
	]
}
